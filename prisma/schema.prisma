generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// ENUMS (Standardizing Statuses)
// -----------------------------------------------------------------------------

enum ProjectStatus {
  PROSPECT
  ACTIVE
  MAINTENANCE
  COMPLETED
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

// -----------------------------------------------------------------------------
// MODELS
// -----------------------------------------------------------------------------

model User {
  // Simple user model for NextAuth (Auth.js) to lock down the dashboard
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?   // If using simple credentials instead of OAuth
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Client {
  id            String    @id @default(cuid())
  name          String
  email         String?
  phone         String?
  hourlyRate    Float     @default(0.0) // Store the default rate for this client
  notes         String?   @db.Text
  
  // Relations
  projects      Project[]
  invoices      Invoice[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Project {
  id              String        @id @default(cuid())
  name            String
  description     String?       @db.Text
  status          ProjectStatus @default(PROSPECT)
  
  // Metadata & Vault
  repositoryUrl   String?
  serverIp        String?
  credentialVault String?       @db.Text // Store encrypted strings or notes here
  
  // Relations
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks           Task[]
  invoices        Invoice[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  deadline    DateTime?
  
  // Relations
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model TimeEntry {
  id          String    @id @default(cuid())
  description String?
  startTime   DateTime
  endTime     DateTime? // Nullable because a timer might still be running
  isBillable  Boolean   @default(true)
  
  // Relations
  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  // Link to an invoice once it's billed
  invoiceId   String?
  invoice     Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Invoice {
  id          String        @id @default(cuid())
  invoiceNum  String        @unique // e.g., "INV-2026-001"
  amount      Float
  status      InvoiceStatus @default(DRAFT)
  dueDate     DateTime?
  paidAt      DateTime?
  
  // Relations
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  projectId   String?
  project     Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  // The time entries billed on this invoice
  timeEntries TimeEntry[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}